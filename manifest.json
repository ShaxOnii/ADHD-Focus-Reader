{
  "manifest_version": 3,
  "name": "ADHD Focus Reader",
  "version": "1.0",
  "description": "Ułatwia czytanie poprzez pogrubianie liter słów i dobiera muzykę w tle na podstawie kontekstu strony.",
  "icons": {
    "16": "icon_16.png",
    "48": "icon_48.png",
    "128": "icon_128.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "offscreen",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ADHD Focus Reader",
    "default_icon": "icon_128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
